# Copy to .env and edit values. .env is gitignored.

# --- Database ---
POSTGRES_USER=thesis
POSTGRES_PASSWORD=thesis
POSTGRES_DB=thesis
# asyncpg driver URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://thesis:thesis@localhost:5433/thesis

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ---------------------------------------------------------------------------
# LLM provider selection (port-adapter pattern)
# ---------------------------------------------------------------------------
# Chat provider  : ollama | azure | deepseek  (default: ollama)
# Embed provider : ollama | azure             (default: ollama)
# The two providers are independent — e.g. use deepseek for chat + ollama for embeddings.
LLM_CHAT_PROVIDER=ollama
LLM_EMBED_PROVIDER=ollama

# ---------------------------------------------------------------------------
# Ollama (used when LLM_CHAT_PROVIDER=ollama or LLM_EMBED_PROVIDER=ollama)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma4:26b
# Model used for transcript extraction (structured JSON output).
# Falls back to OLLAMA_CHAT_MODEL if left empty.
OLLAMA_EXTRACT_MODEL=
OLLAMA_EMBED_MODEL=qwen3-embedding:4b
# Dimension must match the embed model: qwen3-embedding:4b=2560, nomic-embed-text=768, mxbai-embed-large=1024
OLLAMA_EMBED_DIM=2560

# ---------------------------------------------------------------------------
# Azure OpenAI (used when LLM_CHAT_PROVIDER=azure or LLM_EMBED_PROVIDER=azure)
# ---------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_API_VERSION=2024-02-01
# AZURE_CHAT_DEPLOYMENT=gpt-4o          # deployment name for chat/completion
# AZURE_EMBED_DEPLOYMENT=text-embedding-3-small  # deployment name for embeddings

# ---------------------------------------------------------------------------
# DeepSeek (used when LLM_CHAT_PROVIDER=deepseek — chat only, no embeddings)
# Set LLM_EMBED_PROVIDER=ollama or azure when using DeepSeek for chat.
# ---------------------------------------------------------------------------
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_CHAT_MODEL=deepseek-chat

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Comma-separated origins allowed for the React dev server
CORS_ORIGINS=http://localhost:5173
