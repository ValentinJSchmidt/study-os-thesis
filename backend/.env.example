# Copy to .env and edit values. .env is gitignored.

# --- Database ---
POSTGRES_USER=thesis
POSTGRES_PASSWORD=thesis
POSTGRES_DB=thesis
# asyncpg driver URL used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://thesis:thesis@localhost:5433/thesis

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- CORS ---
# Comma-separated origins allowed for the React dev server
CORS_ORIGINS=http://localhost:5173
